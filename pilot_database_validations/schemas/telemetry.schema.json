{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://database-validations/schemas/telemetry.schema.json",
  "title": "Validation Run Telemetry",
  "type": "object",
  "required": ["runId", "timestamp", "mappingVersion", "rulePackVersion", "phases", "quality"],
  "properties": {
    "runId": {"type": "string"},
    "timestamp": {"type": "string", "format": "date-time"},
    "mappingVersion": {"type": "string"},
    "rulePackVersion": {"type": "string"},
    "source": {
      "type": "object",
      "properties": {
        "system": {"type": "string"},
        "queryHash": {"type": "string"},
        "rowCount": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "phases": {
      "type": "object",
      "required": ["extractMs", "validateMs", "reportMs", "totalMs"],
      "properties": {
        "extractMs": {"type": "integer", "minimum": 0},
        "validateMs": {"type": "integer", "minimum": 0},
        "reportMs": {"type": "integer", "minimum": 0},
        "totalMs": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "quality": {
      "type": "object",
      "required": ["validated", "passed", "failed", "warned"],
      "properties": {
        "validated": {"type": "integer", "minimum": 0},
        "passed": {"type": "integer", "minimum": 0},
        "failed": {"type": "integer", "minimum": 0},
        "warned": {"type": "integer", "minimum": 0},
        "byRule": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["ruleId", "severity", "failCount"],
            "properties": {
              "ruleId": {"type": "string"},
              "severity": {"type": "string", "enum": ["ERROR", "WARN", "INFO"]},
              "failCount": {"type": "integer", "minimum": 0}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "system": {
      "type": "object",
      "properties": {
        "peakMemoryMb": {"type": "number", "minimum": 0},
        "recordsPerSecond": {"type": "number", "minimum": 0}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
