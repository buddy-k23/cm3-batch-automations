{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://database-validations/schemas/rules.schema.json",
  "title": "Validation Rule Pack",
  "type": "object",
  "required": ["rulePackId", "version", "status", "rules"],
  "properties": {
    "rulePackId": {"type": "string", "minLength": 1},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "status": {"type": "string", "enum": ["draft", "candidate", "approved", "deprecated", "retired"]},
    "appliesTo": {
      "type": "object",
      "properties": {
        "fileType": {"type": "string", "enum": ["fixed-width", "delimited", "any"]},
        "transactionCodes": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["ruleId", "scope", "severity", "priority", "expression", "messageTemplate", "owner"],
        "properties": {
          "ruleId": {"type": "string", "pattern": "^[A-Z0-9_\\-]+$"},
          "name": {"type": "string"},
          "scope": {"type": "string", "enum": ["field", "record", "group", "file"]},
          "groupBy": {"type": "array", "items": {"type": "string"}},
          "severity": {"type": "string", "enum": ["ERROR", "WARN", "INFO"]},
          "priority": {"type": "integer", "minimum": 1},
          "when": {"type": "string"},
          "expression": {"type": "string", "minLength": 1},
          "messageTemplate": {"type": "string", "minLength": 1},
          "appliesTo": {"type": "array", "items": {"type": "string"}},
          "owner": {"type": "string"},
          "tags": {"type": "array", "items": {"type": "string"}},
          "enabled": {"type": "boolean", "default": true}
        },
        "allOf": [
          {
            "if": {"properties": {"scope": {"const": "group"}}},
            "then": {"required": ["groupBy"]}
          }
        ],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
